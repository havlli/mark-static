{
	"name": "mark-static",
	"version": "0.1.0",
	"description": "File-structure Markdown CMS generator for static SvelteKit documentation sites.",
	"private": false,
	"license": "MIT",
	"packageManager": "pnpm@10.28.0",
	"homepage": "https://havlli.github.io/mark-static/",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/havlli/mark-static.git"
	},
	"bugs": {
		"url": "https://github.com/havlli/mark-static/issues"
	},
	"keywords": [
		"documentation",
		"markdown",
		"sveltekit",
		"static-site",
		"docs"
	],
	"engines": {
		"node": ">=22.12.0",
		"pnpm": ">=10.0.0"
	},
	"files": [
		".github/workflows/deploy.yml",
		".prettierignore",
		".prettierrc",
		"CHANGELOG.md",
		"eslint.config.js",
		"LICENSE",
		"markstatic.config.js",
		"pnpm-lock.yaml",
		"README.md",
		"presets/content",
		"scripts/check-docs.mjs",
		"scripts/create-site.mjs",
		"scripts/generate-content.mjs",
		"src",
		"static/.nojekyll",
		"static/css",
		"static/favicon.png",
		"svelte.config.js",
		"vite-plugin-generate-data.js",
		"vite.config.js"
	],
	"bin": {
		"mark-static": "scripts/create-site.mjs"
	},
	"scripts": {
		"create-site": "node scripts/create-site.mjs",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"generate": "node scripts/generate-content.mjs",
		"docs:check": "node scripts/check-docs.mjs",
		"check:generated": "pnpm generate && git diff --exit-code src/lib/generated/content.js",
		"test": "node --test tests/*.test.mjs",
		"release:check": "pnpm test && pnpm lint && pnpm docs:check && pnpm check:generated && pnpm build && pnpm pack --dry-run",
		"prepublishOnly": "pnpm release:check"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@skeletonlabs/skeleton": "4.15.2",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/eslint": "^9.6.1",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.0.1",
		"svelte": "^5.55.9",
		"tailwindcss": "4.3.0",
		"vite": "^8.0.14"
	},
	"type": "module",
	"dependencies": {
		"@fortawesome/fontawesome-free": "^7.2.0",
		"dom-serializer": "^3.1.1",
		"domutils": "^4.0.2",
		"github-slugger": "^2.0.0",
		"gray-matter": "^4.0.3",
		"highlight.js": "^11.11.1",
		"htmlparser2": "^12.0.0",
		"marked": "^18.0.4",
		"marked-highlight": "^2.2.4",
		"sanitize-html": "^2.17.4"
	},
	"pnpm": {
		"overrides": {
			"cookie": "0.7.2"
		}
	}
}
